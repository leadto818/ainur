        "type": "heading",
        "level": 1,
        "text": "ChatGPT Codex Handoff"
      },
      {
        "type": "heading",
        "level": 2,
        "text": "Overview"
      },
      {
        "type": "paragraph",
        "text": "Use this skill to turn ChatGPT-generated content into a stable file flow that Codex can consume and return back to ChatGPT.\nPrefer a dual-track workflow: keep the original Markdown for humans and create a JSON envelope for machine handoff."
      },
      {
        "type": "heading",
        "level": 2,
        "text": "Input Rules"
      },
